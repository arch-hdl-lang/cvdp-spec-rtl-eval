//!
//! Vending machine controller generated from the CVDP natural-language spec.
//! The design tracks item selection, coin accumulation, dispensing, change return,
//! cancellation, and invalid-operation refund handling in one FSM.
/// Top-level vending machine controller.
///
/// Inputs are sampled on `clk` rising edges; `rst` is asynchronous active high.
/// `item_button` and `cancel` are edge-detected toggle controls. Outputs are
/// registered one-cycle pulses for dispense, return-change, error, and refund events.
/// Event value outputs (`dispense_item_id` and `change_amount`) remain stable
/// after their pulse so a cocotb checker sampling just after the event observes
/// the associated value.
///
/// Transition table: IDLE + button edge -> ITEM_SELECTION with no pulse;
/// IDLE + coin present -> IDLE with error and refund pulse; ITEM_SELECTION +
/// valid nonzero item -> PAYMENT_VALIDATION with item_price visible after the
/// clock; ITEM_SELECTION + invalid nonzero item or cancel edge -> IDLE with an
/// error pulse; PAYMENT_VALIDATION + valid coin below price -> hold and
/// accumulate; PAYMENT_VALIDATION + valid coin meeting price -> DISPENSING_ITEM
/// after storing the total and any change; DISPENSING_ITEM -> IDLE or
/// RETURN_CHANGE with a dispense pulse; RETURN_CHANGE -> IDLE with return_change
/// and change_amount; PAYMENT_VALIDATION + cancel edge -> RETURN_MONEY when
/// money is present, otherwise IDLE, with an error pulse; PAYMENT_VALIDATION +
/// invalid coin -> IDLE with same-cycle error and refund; RETURN_MONEY -> IDLE
/// with return_money when accumulated money was present.
module vending_machine (
  input logic clk,
  input logic rst,
  input logic item_button,
  input logic [2:0] item_selected,
  input logic [3:0] coin_input,
  input logic cancel,
  output logic dispense_item,
  output logic return_change,
  output logic [4:0] item_price,
  output logic [4:0] change_amount,
  output logic [2:0] dispense_item_id,
  output logic error,
  output logic return_money
);

  logic button_edge;
  logic cancel_edge;
  logic coin_present;
  logic coin_valid;
  logic item_present;
  logic item_valid;
  logic [4:0] selected_input_price;
  logic [4:0] coin_value_5;
  logic [4:0] accumulated_next;
  logic [4:0] change_next;
  logic [2:0] mode_r;
  logic item_button_d;
  logic cancel_d;
  logic [2:0] selected_item_r;
  logic [4:0] selected_price_r;
  logic [4:0] coins_accumulated_r;
  logic [4:0] change_amount_r;
  logic dispense_item_r;
  logic return_change_r;
  logic [4:0] item_price_r;
  logic [4:0] change_amount_out_r;
  logic [2:0] dispense_item_id_r;
  logic error_r;
  logic return_money_r;
  assign button_edge = item_button && !item_button_d;
  assign cancel_edge = cancel && !cancel_d;
  assign coin_present = coin_input != 4'd0;
  assign coin_valid = coin_input == 4'd1 || coin_input == 4'd2 || coin_input == 4'd5 || coin_input == 4'd10;
  assign item_present = item_selected != 3'd0;
  assign item_valid = item_selected == 3'd1 || item_selected == 3'd2 || item_selected == 3'd3 || item_selected == 3'd4;
  assign selected_input_price = item_selected == 3'd1 ? 5'd5 : item_selected == 3'd2 ? 5'd10 : item_selected == 3'd3 ? 5'd15 : item_selected == 3'd4 ? 5'd20 : 5'd0;
  assign coin_value_5 = 5'($unsigned(coin_input));
  assign accumulated_next = 5'(coins_accumulated_r + coin_value_5);
  assign change_next = 5'(accumulated_next - selected_price_r);
  assign dispense_item = dispense_item_r;
  assign return_change = return_change_r;
  assign item_price = item_price_r;
  assign change_amount = change_amount_out_r;
  assign dispense_item_id = dispense_item_id_r;
  assign error = error_r;
  assign return_money = return_money_r;
  always_ff @(posedge clk or posedge rst) begin
    if (rst) begin
      cancel_d <= 0;
      change_amount_out_r <= 0;
      change_amount_r <= 0;
      coins_accumulated_r <= 0;
      dispense_item_id_r <= 0;
      dispense_item_r <= 0;
      error_r <= 0;
      item_button_d <= 0;
      item_price_r <= 0;
      mode_r <= 0;
      return_change_r <= 0;
      return_money_r <= 0;
      selected_item_r <= 0;
      selected_price_r <= 0;
    end else begin
      item_button_d <= item_button;
      cancel_d <= cancel;
      dispense_item_r <= 1'b0;
      return_change_r <= 1'b0;
      error_r <= 1'b0;
      return_money_r <= 1'b0;
      if (mode_r == 3'd0) begin
        item_price_r <= 5'd0;
        selected_item_r <= 3'd0;
        selected_price_r <= 5'd0;
        change_amount_r <= 5'd0;
        coins_accumulated_r <= 5'd0;
        if (coin_present) begin
          error_r <= 1'b1;
          return_money_r <= 1'b1;
          mode_r <= 3'd0;
        end else if (button_edge) begin
          change_amount_out_r <= 5'd0;
          dispense_item_id_r <= 3'd0;
          mode_r <= 3'd1;
        end
      end else if (mode_r == 3'd1) begin
        item_price_r <= 5'd0;
        coins_accumulated_r <= 5'd0;
        if (cancel_edge) begin
          error_r <= 1'b1;
          selected_item_r <= 3'd0;
          selected_price_r <= 5'd0;
          mode_r <= 3'd0;
        end else if (item_present && item_valid) begin
          selected_item_r <= item_selected;
          selected_price_r <= selected_input_price;
          item_price_r <= selected_input_price;
          mode_r <= 3'd2;
        end else if (item_present && !item_valid) begin
          error_r <= 1'b1;
          selected_item_r <= 3'd0;
          selected_price_r <= 5'd0;
          mode_r <= 3'd0;
        end
      end else if (mode_r == 3'd2) begin
        item_price_r <= selected_price_r;
        if (cancel_edge) begin
          error_r <= 1'b1;
          if (coins_accumulated_r > 5'd0) begin
            mode_r <= 3'd5;
          end else begin
            selected_item_r <= 3'd0;
            selected_price_r <= 5'd0;
            coins_accumulated_r <= 5'd0;
            item_price_r <= 5'd0;
            mode_r <= 3'd0;
          end
        end else if (coin_present && !coin_valid) begin
          error_r <= 1'b1;
          return_money_r <= 1'b1;
          selected_item_r <= 3'd0;
          selected_price_r <= 5'd0;
          coins_accumulated_r <= 5'd0;
          item_price_r <= 5'd0;
          mode_r <= 3'd0;
        end else if (coin_present && coin_valid) begin
          coins_accumulated_r <= accumulated_next;
          if (accumulated_next >= selected_price_r) begin
            change_amount_r <= change_next;
            mode_r <= 3'd3;
          end
        end
      end else if (mode_r == 3'd3) begin
        item_price_r <= selected_price_r;
        dispense_item_r <= 1'b1;
        dispense_item_id_r <= selected_item_r;
        if (change_amount_r > 5'd0) begin
          mode_r <= 3'd4;
        end else begin
          selected_item_r <= 3'd0;
          selected_price_r <= 5'd0;
          coins_accumulated_r <= 5'd0;
          change_amount_r <= 5'd0;
          item_price_r <= 5'd0;
          mode_r <= 3'd0;
        end
      end else if (mode_r == 3'd4) begin
        return_change_r <= 1'b1;
        change_amount_out_r <= change_amount_r;
        selected_item_r <= 3'd0;
        selected_price_r <= 5'd0;
        coins_accumulated_r <= 5'd0;
        change_amount_r <= 5'd0;
        item_price_r <= 5'd0;
        mode_r <= 3'd0;
      end else if (mode_r == 3'd5) begin
        return_money_r <= coins_accumulated_r > 5'd0;
        selected_item_r <= 3'd0;
        selected_price_r <= 5'd0;
        coins_accumulated_r <= 5'd0;
        change_amount_r <= 5'd0;
        item_price_r <= 5'd0;
        mode_r <= 3'd0;
      end else begin
        mode_r <= 3'd0;
      end
    end
  end

endmodule

