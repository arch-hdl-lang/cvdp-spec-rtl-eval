module axis_upscale
  port clk: in Clock<SysDomain>;
  port resetn: in Reset<Sync, Low>;
  port dfmt_enable: in Bool;
  port dfmt_type: in Bool;
  port dfmt_se: in Bool;
  port s_axis_valid: in Bool;
  port s_axis_data: in UInt<24>;
  port m_axis_ready: in Bool;
  port s_axis_ready: out Bool comb_dep_on(m_axis_ready);
  port m_axis_valid: out Bool comb_dep_on(s_axis_valid);
  port m_axis_data: out UInt<32> comb_dep_on(dfmt_enable, dfmt_se, dfmt_type, s_axis_data);
end module axis_upscale
