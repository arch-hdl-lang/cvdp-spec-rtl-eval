//! ---
//! tags: [dbi, encoding, bus_inversion]
//! ---
//!
//! Data Bus Inversion encoder for a 40-bit bus split into two 20-bit lanes.
//! Each cycle compares incoming data against the previously emitted encoded data
//! and registers the encoded data plus one DBI control bit per lane.

/// Registered two-lane 40-bit Data Bus Inversion encoder.
///
/// The active-low asynchronous reset clears the encoded output and control bits.
module dbi_enc
  port clk: in Clock<SysDomain>;
  port rst_n: in Reset<Async, Low>;
  port data_in: in UInt<40>;
  port data_out: out pipe_reg<UInt<40>, 1> reset rst_n => 40'h0000000000;
  port dbi_cntrl: out pipe_reg<UInt<2>, 1> reset rst_n => 2'b00;

  let cur_g1: UInt<20> = data_in[39:20];
  let cur_g0: UInt<20> = data_in[19:0];
  let prev_g1: UInt<20> = data_out[39:20];
  let prev_g0: UInt<20> = data_out[19:0];
  let diff_g1: UInt<20> = cur_g1 ^ prev_g1;
  let diff_g0: UInt<20> = cur_g0 ^ prev_g0;

  let g1_b00: UInt<5> = diff_g1[0] ? 5'd1 : 5'd0;
  let g1_b01: UInt<5> = diff_g1[1] ? 5'd1 : 5'd0;
  let g1_b02: UInt<5> = diff_g1[2] ? 5'd1 : 5'd0;
  let g1_b03: UInt<5> = diff_g1[3] ? 5'd1 : 5'd0;
  let g1_b04: UInt<5> = diff_g1[4] ? 5'd1 : 5'd0;
  let g1_b05: UInt<5> = diff_g1[5] ? 5'd1 : 5'd0;
  let g1_b06: UInt<5> = diff_g1[6] ? 5'd1 : 5'd0;
  let g1_b07: UInt<5> = diff_g1[7] ? 5'd1 : 5'd0;
  let g1_b08: UInt<5> = diff_g1[8] ? 5'd1 : 5'd0;
  let g1_b09: UInt<5> = diff_g1[9] ? 5'd1 : 5'd0;
  let g1_b10: UInt<5> = diff_g1[10] ? 5'd1 : 5'd0;
  let g1_b11: UInt<5> = diff_g1[11] ? 5'd1 : 5'd0;
  let g1_b12: UInt<5> = diff_g1[12] ? 5'd1 : 5'd0;
  let g1_b13: UInt<5> = diff_g1[13] ? 5'd1 : 5'd0;
  let g1_b14: UInt<5> = diff_g1[14] ? 5'd1 : 5'd0;
  let g1_b15: UInt<5> = diff_g1[15] ? 5'd1 : 5'd0;
  let g1_b16: UInt<5> = diff_g1[16] ? 5'd1 : 5'd0;
  let g1_b17: UInt<5> = diff_g1[17] ? 5'd1 : 5'd0;
  let g1_b18: UInt<5> = diff_g1[18] ? 5'd1 : 5'd0;
  let g1_b19: UInt<5> = diff_g1[19] ? 5'd1 : 5'd0;
  let g1_s00: UInt<5> = g1_b00 +% g1_b01;
  let g1_s01: UInt<5> = g1_b02 +% g1_b03;
  let g1_s02: UInt<5> = g1_b04 +% g1_b05;
  let g1_s03: UInt<5> = g1_b06 +% g1_b07;
  let g1_s04: UInt<5> = g1_b08 +% g1_b09;
  let g1_s05: UInt<5> = g1_b10 +% g1_b11;
  let g1_s06: UInt<5> = g1_b12 +% g1_b13;
  let g1_s07: UInt<5> = g1_b14 +% g1_b15;
  let g1_s08: UInt<5> = g1_b16 +% g1_b17;
  let g1_s09: UInt<5> = g1_b18 +% g1_b19;
  let g1_t00: UInt<5> = g1_s00 +% g1_s01;
  let g1_t01: UInt<5> = g1_s02 +% g1_s03;
  let g1_t02: UInt<5> = g1_s04 +% g1_s05;
  let g1_t03: UInt<5> = g1_s06 +% g1_s07;
  let g1_t04: UInt<5> = g1_s08 +% g1_s09;
  let g1_u00: UInt<5> = g1_t00 +% g1_t01;
  let g1_u01: UInt<5> = g1_t02 +% g1_t03;
  let g1_v00: UInt<5> = g1_u00 +% g1_u01;
  let diff_count_g1: UInt<5> = g1_v00 +% g1_t04;

  let g0_b00: UInt<5> = diff_g0[0] ? 5'd1 : 5'd0;
  let g0_b01: UInt<5> = diff_g0[1] ? 5'd1 : 5'd0;
  let g0_b02: UInt<5> = diff_g0[2] ? 5'd1 : 5'd0;
  let g0_b03: UInt<5> = diff_g0[3] ? 5'd1 : 5'd0;
  let g0_b04: UInt<5> = diff_g0[4] ? 5'd1 : 5'd0;
  let g0_b05: UInt<5> = diff_g0[5] ? 5'd1 : 5'd0;
  let g0_b06: UInt<5> = diff_g0[6] ? 5'd1 : 5'd0;
  let g0_b07: UInt<5> = diff_g0[7] ? 5'd1 : 5'd0;
  let g0_b08: UInt<5> = diff_g0[8] ? 5'd1 : 5'd0;
  let g0_b09: UInt<5> = diff_g0[9] ? 5'd1 : 5'd0;
  let g0_b10: UInt<5> = diff_g0[10] ? 5'd1 : 5'd0;
  let g0_b11: UInt<5> = diff_g0[11] ? 5'd1 : 5'd0;
  let g0_b12: UInt<5> = diff_g0[12] ? 5'd1 : 5'd0;
  let g0_b13: UInt<5> = diff_g0[13] ? 5'd1 : 5'd0;
  let g0_b14: UInt<5> = diff_g0[14] ? 5'd1 : 5'd0;
  let g0_b15: UInt<5> = diff_g0[15] ? 5'd1 : 5'd0;
  let g0_b16: UInt<5> = diff_g0[16] ? 5'd1 : 5'd0;
  let g0_b17: UInt<5> = diff_g0[17] ? 5'd1 : 5'd0;
  let g0_b18: UInt<5> = diff_g0[18] ? 5'd1 : 5'd0;
  let g0_b19: UInt<5> = diff_g0[19] ? 5'd1 : 5'd0;
  let g0_s00: UInt<5> = g0_b00 +% g0_b01;
  let g0_s01: UInt<5> = g0_b02 +% g0_b03;
  let g0_s02: UInt<5> = g0_b04 +% g0_b05;
  let g0_s03: UInt<5> = g0_b06 +% g0_b07;
  let g0_s04: UInt<5> = g0_b08 +% g0_b09;
  let g0_s05: UInt<5> = g0_b10 +% g0_b11;
  let g0_s06: UInt<5> = g0_b12 +% g0_b13;
  let g0_s07: UInt<5> = g0_b14 +% g0_b15;
  let g0_s08: UInt<5> = g0_b16 +% g0_b17;
  let g0_s09: UInt<5> = g0_b18 +% g0_b19;
  let g0_t00: UInt<5> = g0_s00 +% g0_s01;
  let g0_t01: UInt<5> = g0_s02 +% g0_s03;
  let g0_t02: UInt<5> = g0_s04 +% g0_s05;
  let g0_t03: UInt<5> = g0_s06 +% g0_s07;
  let g0_t04: UInt<5> = g0_s08 +% g0_s09;
  let g0_u00: UInt<5> = g0_t00 +% g0_t01;
  let g0_u01: UInt<5> = g0_t02 +% g0_t03;
  let g0_v00: UInt<5> = g0_u00 +% g0_u01;
  let diff_count_g0: UInt<5> = g0_v00 +% g0_t04;

  let invert_g1: Bool = diff_count_g1 > 5'd10;
  let invert_g0: Bool = diff_count_g0 > 5'd10;
  let enc_g1: UInt<20> = invert_g1 ? ~cur_g1 : cur_g1;
  let enc_g0: UInt<20> = invert_g0 ? ~cur_g0 : cur_g0;
  let next_data: UInt<40> = {enc_g1, enc_g0};
  let next_ctrl: UInt<2> = {invert_g1, invert_g0};

  default seq on clk rising;

  seq
    data_out@1 <= next_data;
    dbi_cntrl@1 <= next_ctrl;
  end seq
end module dbi_enc
