module nbit_swizzling
  param DATA_WIDTH: const = 64;
  local param HALF_WIDTH: const = (DATA_WIDTH / 2);
  local param QUARTER_WIDTH: const = (DATA_WIDTH / 4);
  local param EIGHTH_WIDTH: const = (DATA_WIDTH / 8);
  port data_in: in UInt<DATA_WIDTH>;
  port sel: in UInt<2>;
  port data_out: out UInt<DATA_WIDTH> comb_dep_on(data_in, sel);
end module nbit_swizzling
