//! ---
//! tags: [performance-counter, software-read, active-low-reset]
//! ---
//!
//! Parameterized performance counter for CPU-triggered and software-requested events. The counter wraps naturally at CNT_W bits and continuously exposes the current count.

/// Counts trigger events and exposes the live wrapping count.
///
/// Timing table:
/// | reset | sw_req_i | cpu_trig_i | count_q next | p_count_o visible now |
/// | 0     | x        | x          | 0            | 0                     |
/// | 1     | 1        | x          | count_q + 1  | count_q               |
/// | 1     | 0        | 1          | count_q + 1  | count_q               |
/// | 1     | 0        | 0          | count_q      | count_q               |
module cvdp_copilot_perf_counters
  param CNT_W: const = 8;

  port clk: in Clock<SysDomain>;
  port reset: in Reset<Async, Low>;
  port sw_req_i: in Bool;
  port cpu_trig_i: in Bool;
  port p_count_o: out UInt<CNT_W>;

  reg default: reset reset => 0;
  reg count_q: UInt<CNT_W>;

  let inc_value: UInt<CNT_W> = 1;
  let event_seen: Bool = sw_req_i or cpu_trig_i;
  let p_count_o = count_q;

  default seq on clk rising;

  seq
    if event_seen
      count_q <= count_q +% inc_value;
    end if
  end seq
end module cvdp_copilot_perf_counters
