//! ---
//! tags: [division, unsigned-arithmetic, latency, registered-output]
//! ---
//!
//! Unsigned divider with restoring-divider style latency. The module samples operands on a start pulse, iterates one quotient bit per clock, and asserts valid when the quotient and remainder registers hold the completed operation.

/// Top-level unsigned restoring division datapath.
///
/// Input timing: clk rising edge samples start, dividend, and divisor. rst is asynchronous active-low for the CVDP harness and clears all state.
/// Output timing: quotient and remainder update on the final iteration; valid remains asserted with the completed result until another start or reset.
module restoring_division
  param WIDTH: const = 6;
  local param COUNT_W: const = $clog2(WIDTH + 2);
  local param REM_W: const = WIDTH + 1;

  port clk: in Clock<SysDomain>;
  port rst: in Reset<Async, Low>;
  port start: in Bool;
  port dividend: in UInt<WIDTH>;
  port divisor: in UInt<WIDTH>;
  port quotient: out UInt<WIDTH>;
  port remainder: out UInt<WIDTH>;
  port valid: out Bool;

  reg default: reset rst => 0;
  reg dividend_r: UInt<WIDTH>;
  reg divisor_r: UInt<WIDTH>;
  reg quotient_work_r: UInt<WIDTH>;
  reg remainder_work_r: UInt<REM_W>;
  reg quotient_r: UInt<WIDTH>;
  reg remainder_r: UInt<WIDTH>;
  reg valid_r: Bool;
  reg busy_r: Bool;
  reg iter_count_r: UInt<COUNT_W>;

  let rem_low: UInt<WIDTH> = remainder_work_r[WIDTH-1:0];
  let shifted_rem: UInt<REM_W> = {rem_low, dividend_r[WIDTH-1]};
  let divisor_ext: UInt<REM_W> = divisor_r.zext<REM_W>();
  let can_subtract: Bool = shifted_rem >= divisor_ext;
  let subtract_rem: UInt<REM_W> = shifted_rem -% divisor_ext;
  let next_rem: UInt<REM_W> = can_subtract ? subtract_rem : shifted_rem;
  let next_quotient: UInt<WIDTH> = {quotient_work_r[WIDTH-2:0], can_subtract};
  let next_dividend: UInt<WIDTH> = {dividend_r[WIDTH-2:0], 1'b0};
  let final_iter: Bool = iter_count_r == (WIDTH - 1).resize<COUNT_W>();

  let quotient = quotient_r;
  let remainder = remainder_r;
  let valid = valid_r;

  default seq on clk rising;

  seq
    if start and not busy_r
      dividend_r <= dividend;
      divisor_r <= divisor;
      quotient_work_r <= 0;
      remainder_work_r <= 0;
      quotient_r <= 0;
      remainder_r <= 0;
      iter_count_r <= 0;
      busy_r <= true;
      valid_r <= false;
    elsif busy_r
      dividend_r <= next_dividend;
      quotient_work_r <= next_quotient;
      remainder_work_r <= next_rem;
      if final_iter
        quotient_r <= next_quotient;
        remainder_r <= next_rem[WIDTH-1:0];
        busy_r <= false;
        valid_r <= true;
      else
        iter_count_r <= iter_count_r +% 1;
        valid_r <= false;
      end if
    end if
  end seq
end module restoring_division
