//!
//! Clock jitter detection by counting primary clock cycles between sampled rising edges of system_clk.
//! The design uses synchronous reset and produces a one-cycle registered jitter_detected pulse for intervals outside JITTER_THRESHOLD +/- 1.
/// Counts clk cycles between consecutive sampled rising edges of system_clk and flags interval jitter.
///
/// Timing: system_clk is sampled on the rising edge of clk. jitter_detected is a registered one-cycle pulse visible one clk after an out-of-range completed interval is observed.
module clock_jitter_detection_module #(
  parameter int JITTER_THRESHOLD = 5
) (
  input logic clk,
  input logic system_clk,
  input logic rst,
  output logic jitter_detected
);

  logic edge_seen;
  logic [31:0] completed_interval;
  logic late_jitter;
  logic [32:0] early_margin;
  logic early_jitter;
  logic interval_jitter;
  logic jitter_now;
  logic [31:0] edge_count;
  logic [31:0] edge_count_r;
  logic prev_system_clk;
  logic have_edge;
  assign edge_seen = system_clk && !prev_system_clk;
  assign completed_interval = 32'(edge_count + 32'd1);
  assign late_jitter = completed_interval > JITTER_THRESHOLD + 1;
  assign early_margin = completed_interval + 32'd1;
  assign early_jitter = early_margin < JITTER_THRESHOLD;
  assign interval_jitter = early_jitter || late_jitter;
  assign jitter_now = edge_seen && have_edge && interval_jitter;
  always_ff @(posedge clk) begin
    if (rst) begin
      edge_count <= 0;
      edge_count_r <= 0;
      have_edge <= 0;
      jitter_detected <= 1'b0;
      prev_system_clk <= 0;
    end else begin
      prev_system_clk <= system_clk;
      jitter_detected <= jitter_now;
      if (edge_seen) begin
        if (have_edge) begin
          edge_count_r <= completed_interval;
        end else begin
          edge_count_r <= 0;
          have_edge <= 1'b1;
        end
        edge_count <= 0;
      end else if (have_edge) begin
        edge_count <= 32'(edge_count + 32'd1);
      end else begin
        edge_count <= 0;
      end
    end
  end

endmodule

