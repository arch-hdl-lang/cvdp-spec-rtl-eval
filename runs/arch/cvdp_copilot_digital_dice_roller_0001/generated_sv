//! tags: [dice, fsm, counter, button, reset]
//! refs: []
//! ---
//!
//! Digital dice roller generated from the CVDP natural-language specification.
//! The design rolls a 1-to-6 value while the button is pressed, then displays the last rolled value after release.
/// Two-state digital dice roller FSM.
///
/// Timing: `button` is sampled on the rising edge of `clk`; `reset_n` is asynchronous active-low.
/// `dice_value` is a registered, externally visible display value that is reset to `000`, held in IDLE,
/// and updated on the release edge from the last rolling value.
///
/// Transition table:
/// current state | input condition | next state | externally visible output/action
/// IDLE          | button == 0     | IDLE       | dice_value holds its displayed register
/// IDLE          | button == 1     | ROLLING    | rolling register advances into the 1..6 range; dice_value holds
/// ROLLING       | button == 1     | ROLLING    | rolling register advances modulo 1..6; dice_value holds
/// ROLLING       | button == 0     | IDLE       | dice_value captures the last rolling register value on this edge
module digital_dice_roller (
  input logic clk,
  input logic reset_n,
  input logic button,
  output logic [2:0] dice_value
);

  typedef enum logic [0:0] {
    IDLE = 1'd0,
    ROLLING = 1'd1
  } digital_dice_roller_state_t;
  
  digital_dice_roller_state_t state_r, state_next;
  
  logic [2:0] roll_value;
  logic [2:0] shown_value;
  
  logic roll_wrap;
  assign roll_wrap = roll_value == 3'd0 || roll_value == 3'd6;
  logic [2:0] roll_next;
  assign roll_next = roll_wrap ? 3'd1 : 3'(roll_value + 3'd1);
  assign dice_value = shown_value;
  
  always_ff @(posedge clk or negedge reset_n) begin
    if ((!reset_n)) begin
      state_r <= IDLE;
      roll_value <= 0;
      shown_value <= 0;
    end else begin
      state_r <= state_next;
      unique case (state_r)
        IDLE: begin
          if (button) begin
            roll_value <= roll_next;
          end
        end
        ROLLING: begin
          if (button) begin
            roll_value <= roll_next;
          end else begin
            shown_value <= roll_value;
          end
        end
        default: ;
      endcase
    end
  end
  
  always_comb begin
    state_next = state_r; // hold by default
    unique case (state_r)
      IDLE: begin
        if (button) state_next = ROLLING;
      end
      ROLLING: begin
        if (!button) state_next = IDLE;
      end
      default: state_next = state_r;
    endcase
  end
  
  always_comb begin
    unique case (state_r)
      IDLE: begin
      end
      ROLLING: begin
      end
      default: ;
    endcase
  end
  
  // synopsys translate_off
  _auto_reach_IDLE: cover property (@(posedge clk) state_r == IDLE);
  _auto_reach_ROLLING: cover property (@(posedge clk) state_r == ROLLING);
  _auto_tr_IDLE_to_ROLLING: cover property (@(posedge clk) state_r == IDLE && state_next == ROLLING);
  _auto_tr_ROLLING_to_IDLE: cover property (@(posedge clk) state_r == ROLLING && state_next == IDLE);
  // synopsys translate_on

endmodule

